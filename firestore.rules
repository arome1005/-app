// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: messages
// Document ID: auto-generated
// Fields:
//   - role: string (required, enum: ["user", "model"])
//   - text: string (required)
//   - timestamp: number (required)
//   - uid: string (required)
//   - module: string (required, enum: ["chat", "listen", "speak", "read", "write"])
//
// Collection: wordBank
// Document ID: auto-generated
// Fields:
//   - word: string (required)
//   - timestamp: number (required)
//   - uid: string (required)
//   - mastery: number (optional)
//
// Collection: vocabularyProgress
// Document ID: auto-generated
// Fields:
//   - word: string (required)
//   - meaning: string (required)
//   - phonetic: string (required)
//   - knownCount: number (required)
//   - lastReview: number (required)
//   - nextReview: number (required)
//   - status: string (required, enum: ["learning", "mastered", "forgotten", "vague"])
//   - uid: string (required)
//   - mnemonic: string (optional)
//   - sentences: list (optional)
//   - extended: list (optional)
//
// Collection: checkIns
// Document ID: auto-generated
// Fields:
//   - uid: string (required)
//   - date: string (required, YYYY-MM-DD)
//   - wordCount: number (required)
//   - timestamp: number (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidMessage(data) {
      return data.role in ['user', 'model'] &&
             data.text is string && data.text.size() < 50000 &&
             data.timestamp is number &&
             data.uid is string && data.uid == request.auth.uid &&
             data.module in ['chat', 'listen', 'speak', 'read', 'write'];
    }

    function isValidWord(data) {
      return data.word is string && data.word.size() < 100 &&
             data.timestamp is number &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidVocabularyProgress(data) {
      return data.word is string && data.word.size() < 100 &&
             data.meaning is string && data.meaning.size() < 500 &&
             data.phonetic is string && data.phonetic.size() < 100 &&
             data.knownCount is number &&
             data.lastReview is number &&
             data.nextReview is number &&
             data.status in ['learning', 'mastered', 'forgotten', 'vague'] &&
             data.uid is string && data.uid == request.auth.uid &&
             (!('mnemonic' in data) || (data.mnemonic is string && data.mnemonic.size() < 1000)) &&
             (!('sentences' in data) || data.sentences is list) &&
             (!('extended' in data) || data.extended is list);
    }

    function isValidCheckIn(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.wordCount is number &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /messages/{messageId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /wordBank/{wordId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidWord(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidWord(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /vocabularyProgress/{progressId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidVocabularyProgress(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidVocabularyProgress(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /checkIns/{checkInId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidCheckIn(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /test/{docId} {
      allow read: if true; // For connection testing
    }
  }
}
